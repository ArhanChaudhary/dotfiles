{
  "title": "Map Ctrl keys to ISSCli commands",
  "rules": [
    {
      "description": "Ctrl + K/J/1-9 to ISSCli",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "j",
            "modifiers": { "mandatory": ["control"] }
          },
          "to": [
            {
              "shell_command": "/usr/local/bin/ISSCli l"
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "k",
            "modifiers": { "mandatory": ["control"] }
          },
          "to": [
            {
              "shell_command": "/usr/local/bin/ISSCli r"
            }
          ]
        },

        {
          "type": "basic",
          "from": {
            "key_code": "1",
            "modifiers": { "mandatory": ["control"] }
          },
          "to": [{ "shell_command": "/usr/local/bin/ISSCli i 1" }]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "2",
            "modifiers": { "mandatory": ["control"] }
          },
          "to": [{ "shell_command": "/usr/local/bin/ISSCli i 2" }]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "3",
            "modifiers": { "mandatory": ["control"] }
          },
          "to": [{ "shell_command": "/usr/local/bin/ISSCli i 3" }]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "4",
            "modifiers": { "mandatory": ["control"] }
          },
          "to": [{ "shell_command": "/usr/local/bin/ISSCli i 4" }]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "5",
            "modifiers": { "mandatory": ["control"] }
          },
          "to": [{ "shell_command": "/usr/local/bin/ISSCli i 5" }]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "6",
            "modifiers": { "mandatory": ["control"] }
          },
          "to": [{ "shell_command": "/usr/local/bin/ISSCli i 6" }]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "7",
            "modifiers": { "mandatory": ["control"] }
          },
          "to": [{ "shell_command": "/usr/local/bin/ISSCli i 7" }]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "8",
            "modifiers": { "mandatory": ["control"] }
          },
          "to": [{ "shell_command": "/usr/local/bin/ISSCli i 8" }]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "9",
            "modifiers": { "mandatory": ["control"] }
          },
          "to": [{ "shell_command": "/usr/local/bin/ISSCli i 9" }]
        }
      ]
    }
  ]
}
