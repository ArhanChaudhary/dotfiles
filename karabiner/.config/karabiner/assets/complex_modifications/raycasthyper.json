{
  "title": "Raycast Hyper",
  "rules": [
    {
      "description": "Caps Lock -> Escape when tapped, Hyper when held",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": { "optional": ["any"] }
          },
          "to": [
            {
              "key_code": "left_shift",
              "modifiers": ["left_command", "left_control"]
            }
          ],
          "to_if_alone": [{ "key_code": "escape" }]
        }
      ]
    }
  ]
}
