  "auto_install_extensions": {
    "astro": true,
    "bearded-icon-theme": true,
    "discord-presence": true,
    "dockerfile": true,
    "git-firefly": true,
    "html": true,
    "make": true,
    "mdx": true,
    "nix": true,
    "svelte": true,
    "toml": true,
    "typst": true,
    "wakatime": true,
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "subtle",
    "disabled_globs": ["*.typ", "*.mdx", "*.md"],
  },
  // Workspace restoration behavior.
  //   All workspaces ("last_session"), last workspace ("last_workspace") or "none"
  "restore_on_startup": "last_session",
  // Whether to attempt to restore previous file's state when opening it again.
  // E.g. for editors, selections, folds and scroll positions are restored
  "restore_on_file_reopen": true,
  // Whether to automatically close files that have been deleted on disk.
  "close_on_file_delete": false,

  // inline errors
  // https://github.com/zed-industries/zed/issues/4901#issuecomment-2914294765
  "diagnostics": {
    "button": true,
    "include_warnings": true,
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 2,
      "min_column": 0,
      "max_severity": null,
    },
  },
  "icon_theme": "Bearded Icon Theme",
  "inlay_hints": {
    "enabled": true,
  },
  "buffer_font_features": {
    "calt": 1,
  },
  "ui_font_family": ".SystemUIFont",
  "preview_tabs": {
    "enable_preview_from_file_finder": true,
  },
  "relative_line_numbers": "enabled",
  "gutter": {
    "line_numbers": true,
  },
  "minimap": {
    "show": "never",
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
        "inlayHints": {
          "maxLength": null,
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true,
          },
          "closureReturnTypeHints": {
            "enable": "always",
          },
        },
        "completion": {
          "snippets": {
            "custom": {
              "println": {
                "postfix": "pl",
                "body": "println!(\"{:?}\", ${receiver});",
                "description": "Print the expression using Debug formatting",
                "scope": "expr",
              },
              "Ok": {
                "postfix": "ok",
                "body": "Ok(${receiver})",
                "description": "Wrap the expression in a `Result::Ok`",
                "scope": "expr",
              },
              "Box::pin": {
                "postfix": "pinbox",
                "body": "Box::pin(${receiver})",
                "requires": "std::boxed::Box",
                "description": "Put the expression into a pinned `Box`",
                "scope": "expr",
              },
              "Arc::new": {
                "postfix": "arc",
                "body": "Arc::new(${receiver})",
                "requires": "std::sync::Arc",
                "description": "Put the expression into an `Arc`",
                "scope": "expr",
              },
              "Some": {
                "postfix": "some",
                "body": "Some(${receiver})",
                "description": "Wrap the expression in an `Option::Some`",
                "scope": "expr",
              },
              "Err": {
                "postfix": "err",
                "body": "Err(${receiver})",
                "description": "Wrap the expression in a `Result::Err`",
                "scope": "expr",
              },
              "Rc::new": {
                "postfix": "rc",
                "body": "Rc::new(${receiver})",
                "requires": "std::rc::Rc",
                "description": "Put the expression into an `Rc`",
                "scope": "expr",
              },
            },
          },
        },
      },
    },
    "tinymist": {
      "settings": {
        "outputPath": "$root/$name",
        "formatterMode": "typstyle",
        "formatterIndentSize": 4,
      },
    },
    "tailwindcss-language-server": {
      "settings": {
        "classAttributes": ["class", "className", "ngClass", "styles"],
        "includeLanguages": {
          "rust": "html",
        },
        "experimental": {
          "classRegex": [
            "class=\"([^\"]*)",
            "class={\"([^\"}]*)",
            "class=format!({\"([^\"}]*)",

            "\\.className\\s*[+]?=\\s*['\"]([^'\"]*)['\"]",
            "\\.setAttributeNS\\(.*,\\s*['\"]class['\"],\\s*['\"]([^'\"]*)['\"]",
            "\\.setAttribute\\(['\"]class['\"],\\s*['\"]([^'\"]*)['\"]",
            "\\.classList\\.add\\(['\"]([^'\"]*)['\"]",
            "\\.classList\\.remove\\(['\"]([^'\"]*)['\"]",
            "\\.classList\\.toggle\\(['\"]([^'\"]*)['\"]",
            "\\.classList\\.contains\\(['\"]([^'\"]*)['\"]",
            "\\.classList\\.replace\\(\\s*['\"]([^'\"]*)['\"]",
            "\\.classList\\.replace\\([^,)]+,\\s*['\"]([^'\"]*)['\"]",
          ],
        },
      },
    },
  },
  "linked_edits": true,
  "show_whitespaces": "none",
  "show_edit_predictions": true,
  "remove_trailing_whitespace_on_save": true,
  "wrap_guides": [80, 120],
  "file_types": {
    "markdown": ["*.mdx"],
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"],
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "on_yank",
  },
  "ui_font_size": 15,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "zedokai-darkest-machine",
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "cursor_blink": false,

  "profiles": {
    "Focus": {
      "ui_font_size": 16,
      "buffer_font_size": 17,
      "tab_bar": {
        "show": false,
      },
      "toolbar": {
        "breadcrumbs": false,
        "quick_actions": false,
      },
      "gutter": {
        "folds": false,
        "breakpoints": false,
        "runnables": false,
      },
      "current_line_highlight": "none",
      "scrollbar": {
        "show": "never",
        "cursors": false,
        "git_diff": false,
        "diagnostics": "none",
        "search_results": false,
        "selected_symbol": false,
      },
    },
  },
  "centered_layout": {
    "left_padding": 0.1,
    "right_padding": 0.1,
  },
  "terminal": {
    "env": {
      "EDITOR": "hx",
    },
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    // above is default from Zed
    "**/out",
    "**/.turbo",
    "**/.vscode-test",
    "**/.vscode",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/report",
    "**/node_modules",
  ],
  "semantic_tokens": "combined",
}
